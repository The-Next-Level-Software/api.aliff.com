{
    "name": "nextlevel-backend-prisma",
    "version": "1.0.0",
    "description": "Next Level Software Backend - Node.js + Express + Prisma + PostgreSQL API with Swagger, Tests, and CI/CD ready structure",
    "main": "src/index.js",
    "type": "module",
    "scripts": {
        "dev": "nodemon ./src/index.js",
        "start": "node ./src/index.js",
        "backup": "node ./src/scripts/backup.run.js",
        "migrate:db": "node ./src/scripts/migrate-db.run.js",
        "seed": "node ./src/seed/seed.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "jest --runInBand",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio",
        "prisma:push": "prisma db push"
    },
    "keywords": [
        "nodejs",
        "express",
        "prisma",
        "postgresql",
        "swagger",
        "jest",
        "backend",
        "api",
        "redis",
        "socket.io"
    ],
    "author": "Next Level Software",
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.4",
        "globals": "^16.5.0",
        "nodemon": "^3.1.10",
        "prettier": "^3.6.2"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1044.0",
        "@google/genai": "^1.52.0",
        "@prisma/client": "^6.2.0",
        "@supabase/supabase-js": "^2.105.3",
        "apple-signin-auth": "^2.0.0",
        "archiver": "^7.0.1",
        "aws-sdk": "^2.1693.0",
        "axios": "^1.16.0",
        "bcryptjs": "^3.0.3",
        "bullmq": "^5.63.0",
        "chalk": "^5.6.2",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.1.0",
        "express-rate-limit": "^8.2.1",
        "express-validator": "^7.3.1",
        "form-data": "^4.0.5",
        "google-auth-library": "^10.6.2",
        "helmet": "^8.1.0",
        "http": "^0.0.1-security",
        "http-status-codes": "^2.3.0",
        "ioredis": "^5.8.2",
        "joi": "^18.0.1",
        "jsonwebtoken": "^9.0.2",
        "module-alias": "^2.2.3",
        "moment": "^2.30.1",
        "morgan": "^1.10.1",
        "multer": "^2.1.1",
        "node-cron": "^4.2.1",
        "nodemailer": "^7.0.10",
        "pg": "^8.13.1",
        "pino": "^10.1.0",
        "pino-pretty": "^13.1.2",
        "prisma": "^6.2.0",
        "readline": "^1.3.0",
        "redis": "^5.10.0",
        "sharp": "^0.34.5",
        "socket.io": "^4.8.1",
        "systeminformation": "^5.27.11"
    },
    "_moduleAliases": {
        "@config": "src/config",
        "@constants": "src/constants",
        "@middleware": "src/middleware",
        "@models": "src/models",
        "@services": "src/services",
        "@controllers": "src/controllers",
        "@routes": "src/routes",
        "@utils": "src/utils",
        "@startup": "src/startup"
    },
    "nodemonConfig": {
        "ignore": [
            "backups/**",
            "logs/**"
        ]
    }
}
